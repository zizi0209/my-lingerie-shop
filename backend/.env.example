# Database
DATABASE_URL="postgresql://username:password@localhost:5432/my_lingerie_shop?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# TripoSR 3D Model Generation
TRIPOSR_ENDPOINT="https://stabilityai-triposr.hf.space"
TRIPOSR_TIMEOUT_MS=120000
TRIPOSR_HEALTHCHECK_INTERVAL_MS=300000
TRIPOSR_API_MODE="fastapi"

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# GitHub OAuth2 Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Auth Secret
AUTH_SECRET=your-generated-secret-key

# NextAuth URL
NEXTAUTH_URL=https://yourdomain.com

# Redis
REDIS_URL=redis://localhost:6379

# Alerting Configuration (for critical security events)
# Slack webhook for security alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook for security alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Email alerting
ALERT_EMAIL=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=alerts@yourdomain.com

# Virtual Try-On (Option A: ZeroGPU self-hosted + fallback public)
TRYON_SELF_HOSTED_URL=""
TRYON_SELF_HOSTED_ENDPOINT="/call/tryon"
TRYON_SELF_HOSTED_TYPE="idm"
TRYON_SELF_HOSTED_NAME="ZeroGPU-SelfHosted"
TRYON_PRIMARY_PROVIDERS="ZeroGPU-SelfHosted,FASHN-VTON-1.5,IDM-VTON"
TRYON_PROVIDER_TIMEOUT_MS=120000
TRYON_SELF_HOSTED_TIMEOUT_MS=180000
TRYON_DMVTON_ENABLED=false
TRYON_DMVTON_URL="http://127.0.0.1:8001"
TRYON_DMVTON_ENDPOINT="/tryon"
TRYON_DMVTON_TIMEOUT_MS=180000
TRYON_SELF_HOSTED_READINESS_TIMEOUT_MS=4000
TRYON_SELF_HOSTED_READINESS_TTL_MS=30000
TRYON_HEALTH_WINDOW_MS=900000
TRYON_FAIL_RATE_WARNING_THRESHOLD=0.4
TRYON_TIMEOUT_WARNING_THRESHOLD=2
TRYON_MAX_CONCURRENT=1
TRYON_PRIMARY_PARALLEL_BATCH_SIZE=1
TRYON_FALLBACK_PARALLEL_BATCH_SIZE=1
TRYON_DEMO_LEARNING=false
TRYON_PERMISSIVE_PROVIDERS="FASHN-VTON-1.5,DM-VTON-Local"
TRYON_NONCOMMERCIAL_PROVIDERS="StableVITON,IDM-VTON"
TRYON_FORCE_ASYNC=true
TRYON_USE_GEMINI=false

# Worker retry (set in tryon-worker runtime env)
VTON_CUSTOM_API_URL=""
VTON_CUSTOM_API_FALLBACK_URL=""
VTON_CUSTOM_API_FALLBACK_PROVIDER="custom-api-fallback"
VTON_CUSTOM_API_QUALITY_THRESHOLD="0.85"
VTON_CUSTOM_API_TIMEOUT_MS=180000
VTON_CUSTOM_API_RETRIES=2
VTON_CUSTOM_API_RETRY_BASE_MS=800
